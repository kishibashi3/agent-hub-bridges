# agent-hub-bridges — env template
#
# 各 bridge は 自分が必要な行だけ 使う。 不要な行は コメントアウトで残してよい。
# CLI 引数 (`--participant` 等) が優先で、 未指定なら ここの env から fallback。

# ===== 全 bridge 共通 =====================================================

# agent-hub MCP endpoint (必須)。 staging / production で URL を切り替える。
AGENT_HUB_URL=http://localhost:3000/mcp

# agent-hub auth 用 GitHub PAT (必須)。 read-only で良い。
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 自分の handle (= bridge ごとの peer 名)。 CLI `--participant` で override 可。
AGENT_HUB_PARTICIPANT=

# 表示名 (任意)。
AGENT_HUB_DISPLAY_NAME=

# tenant 名 (任意)。 未指定なら default tenant (雑談室) に入る。
AGENT_HUB_TENANT=

# LLM 系 bridge の作業 root path (任意)。 未指定なら cwd。 relay 系 bridge は無視。
AGENT_HUB_WORKDIR=

# inbox safety-net poll interval (秒)。 SDK 既定 30 秒。 必要時のみ調整。
# AGENT_HUB_INBOX_POLL_INTERVAL_S=30

# ===== [claude] / [claude-p] / [client-codex] / [gemini] bridge ===========
# GitHub App IAT モード (issue #73): bot identity で PR/issue コメントを投稿する。
# 3 変数すべて設定すると有効になる。未設定時は PAT fallback (従来動作)。
# GITHUB_APP_ID=4008981
# GITHUB_APP_PRIVATE_KEY=/path/to/private-key.pem
# GITHUB_APP_INSTALLATION_ID=

# ===== [claude] bridge ====================================================
# Claude Agent SDK は claude CLI 認証 fallback が効くので key は任意。
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ===== [slack] bridge =====================================================
# Slack Socket Mode の 2 種類の token (両方必須)。
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxx
# SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxxx
# 未 bind peer の reply 先 channel (任意)。
# SLACK_DEFAULT_CHANNEL=C0123456789

# ===== [gemini] bridge ====================================================
# gemini CLI は npm 経由で別途 install (`npm i -g @google/gemini-cli`)。
# Gemini API key (CLI 側が読む)。
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxx
# モデル名 (任意; CLI `--model` で override)。
# GEMINI_MODEL=gemini-2.5-flash

# ===== [a2a] bridge =======================================================
# 外部 A2A agent の base URL (必須)。 起動時に Agent Card を fetch して
# 自動 register、 以降は agent-hub の peer として bidirectional に動く。
# A2A_AGENT_URL=https://external-agent.example.com
#
# Agent Card endpoint の relative path (任意、 default `/.well-known/agent.json`)。
# agent server が non-standard な path に置いている場合のみ override。
# A2A_AGENT_CARD_PATH=/.well-known/agent.json
